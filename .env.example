# BRIM Automotive — Environment Variables
# Copy to .env and fill in your values.
# Never commit .env to git.

# Supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-anon-public-key
SUPABASE_SECRET_KEY=your-service-role-key  # Server-side only, never expose

# Site
SITE_URL=https://brimautomotive.co.ke

# WhatsApp (BRIM's WhatsApp Business number, with country code, no +)
WHATSAPP_NUMBER=254712000001
